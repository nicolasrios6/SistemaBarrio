@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="container mt-5" style="max-width: 540px">
    <div class="text-center">
        <h1 class="display-1 text-danger">403</h1>
        <h4 class="mb-3">No tenés permiso para acceder a esta sección</h4>
        <p class="text-muted mb-4">
            Tu usuario no tiene los permisos necesarios para ver esta página.
            Si creés que es un error, contactá al administrador.
        </p>
        <a asp-controller="Visita" asp-action="Index" class="btn btn-primary">
            Volver al panel
        </a>
    </div>
</div>