@{
    ViewData["Title"] = "Página no encontrada";
}

<div class="container mt-5" style="max-width: 540px">
    <div class="text-center">
        <h1 class="display-1 text-warning">404</h1>
        <h4 class="mb-3">Página no encontrada</h4>
        <p class="text-muted mb-4">
            La página que buscás no existe o fue movida.
        </p>
        <a asp-controller="Visita" asp-action="Index" class="btn btn-primary">
            Volver al panel
        </a>
    </div>
</div>