@model SistemaBarrio.ViewModels.Visitas.RegistrarVisitaViewModel;

@{
    ViewData["Title"] = "Registrar ingreso";
}

<div class="container mt-4" style="max-width: 580px">
    <h4 class="mb-4">Registrar ingreso</h4>

    @* ── PASO 1: Buscar por DNI ───────────────────────────── *@
    <div class="card mb-3">
        <div class="card-body">
            <label class="form-label fw-semibold">DNI del visitante</label>
            <div class="input-group">
                <input type="text" id="inputDni" class="form-control"
                       placeholder="Ej: 35123456" inputmode="numeric" maxlength="8" pattern="\d*"
                       oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                <button type="button" id="btnBuscar" class="btn btn-primary">Buscar</button>
            </div>
            <div id="mensajeBusqueda" class="mt-2 small"></div>
        </div>
    </div>

    @* ── PASO 2 y 3: Se muestran luego de buscar ─────────── *@
    <form asp-action="Registrar" method="post" id="formRegistrar" class="d-none">
        @Html.AntiForgeryToken()

        @* Campos ocultos que se completan por JS *@
        <input type="hidden" asp-for="VisitanteId" id="hiddenVisitanteId" />
        <input type="hidden" asp-for="Dni" id="hiddenDni" />
        <input type="hidden" id="hiddenDomicilioId" name="DomicilioId" />    @* ✅ nuevo *@
        <input type="hidden" id="hiddenPropietarioId" name="PropietarioId" /> @* ✅ nuevo *@

        @* ── PASO 2a: Visitante encontrado ───────────────── *@
        <div id="seccionVisitanteEncontrado" class="card mb-3 border-success d-none">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <span>Visitante registrado</span>
                <span id="badgeAutorizacionTipo" class="badge bg-warning text-dark d-none">
                    ✓ <span id="textoAutorizacionTipo"></span>
                </span>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Nombre:</strong> <span id="textoNombre"></span></p>
                <p class="mb-0"><strong>DNI:</strong> <span id="textoDni"></span></p>

                <div id="badgeAutorizacion" class="mt-2 p-2 bg-light rounded border d-none">
                    <p class="mb-1 small text-success fw-semibold">✓ Visitante autorizado</p>
                    <p class="mb-1 small">
                        <span class="text-muted">Domicilio:</span>
                        <span id="textoAutorizacionDomicilio"></span>
                    </p>
                    <p class="mb-0 small">
                        <span class="text-muted">Propietario:</span>
                        <span id="textoAutorizacionPropietario"></span>
                    </p>
                </div>

                <div id="seccionSelectorAutorizacion" class="mt-3 d-none">
                    <label class="form-label fw-semibold small text-warning">
                        ⚠ Múltiples autorizaciones — seleccioná el domicilio
                    </label>
                    <select id="selectAutorizacion" class="form-select">
                        <option value="">-- Seleccioná el domicilio que viene a visitar --</option>
                    </select>
                </div>
            </div>
        </div>

        @* ── PASO 2b: Visitante nuevo ─────────────────────── *@
        <div id="seccionVisitanteNuevo" class="card mb-3 d-none border-warning">
            <div class="card-header bg-warning">Visitante nuevo — completar datos</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Apellido</label>
                    <input asp-for="Apellido" class="form-control" placeholder="Ej: Pérez" />
                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                </div>
            </div>
        </div>

        @* ── PASO 3: Datos de la visita ───────────────────── *@
        <div id="seccionVisita" class="card mb-3 d-none">
            <div class="card-header">Datos de la visita</div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="DomicilioId" class="form-label"></label>
                    <select asp-items="Model.Domicilios"
                            class="form-select" id="selectDomicilio">
                        <option value="">-- Seleccionar domicilio --</option>
                    </select>
                    <span asp-validation-for="DomicilioId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PropietarioId" class="form-label"></label>
                    <select class="form-select"
                            id="selectPropietario" disabled>
                        <option value="">-- Primero seleccioná un domicilio --</option>
                    </select>
                    <span asp-validation-for="PropietarioId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div id="seccionBotones" class="d-flex gap-2 d-none">
            <button type="submit" class="btn btn-success">Confirmar ingreso</button>
            <a asp-action="Index" asp-controller="Visita" id="btnCancelar" class="btn btn-outline-secondary">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const btnBuscar           = document.getElementById('btnBuscar');
        const inputDni            = document.getElementById('inputDni');
        const mensajeBusqueda     = document.getElementById('mensajeBusqueda');
        const formRegistrar       = document.getElementById('formRegistrar');
        const seccionEncontrado   = document.getElementById('seccionVisitanteEncontrado');
        const seccionNuevo        = document.getElementById('seccionVisitanteNuevo');
        const seccionVisita       = document.getElementById('seccionVisita');
        const seccionBotones      = document.getElementById('seccionBotones');
        const hiddenVisitanteId   = document.getElementById('hiddenVisitanteId');
        const hiddenDni           = document.getElementById('hiddenDni');
        const selectDomicilio     = document.getElementById('selectDomicilio');
        const selectPropietario   = document.getElementById('selectPropietario');

        async function buscarVisitante() {
            const dni = inputDni.value.trim();

            if (!dni) {
                mensajeBusqueda.innerHTML = '<span class="text-danger">Ingresá un DNI</span>';
                return;
            }

            btnBuscar.disabled    = true;
            btnBuscar.textContent = 'Buscando...';

            try {
                const response = await fetch(`/Visita/BuscarPorDni?dni=${dni}`);
                const data     = await response.json();

                resetFormulario();

                if (!data.encontrado) {
                    // Visitante nuevo
                    hiddenDni.value = dni;
                    seccionNuevo.classList.remove('d-none');
                    formRegistrar.classList.remove('d-none');
                    seccionVisita.classList.remove('d-none');
                    seccionBotones.classList.remove('d-none');
                    mensajeBusqueda.innerHTML =
                        '<span class="text-warning">DNI no registrado — completá los datos</span>';
                    return;
                }



                // Visitante encontrado
                hiddenVisitanteId.value = data.id;
                document.getElementById('textoNombre').textContent =
                    `${data.apellido}, ${data.nombre}`;
                document.getElementById('textoDni').textContent = data.dni;

                // ── Si tiene autorización vigente ──────────────────────
                if (data.tieneAutorizacion) {
                document.getElementById('badgeAutorizacion').classList.remove('d-none');
                document.getElementById('badgeAutorizacionTipo').classList.remove('d-none');

                if (data.autorizaciones.length === 1) {
                    // Una sola autorización — precarga automático como antes
                    const auth = data.autorizaciones[0];

                    document.getElementById('textoAutorizacionTipo').textContent = auth.tipo;
                    document.getElementById('textoAutorizacionDomicilio').textContent = auth.domicilio;
                    document.getElementById('textoAutorizacionPropietario').textContent = auth.propietario;

                    document.getElementById('hiddenDomicilioId').value  = auth.domicilioId;
                    document.getElementById('hiddenPropietarioId').value = auth.propietarioId;

                    selectDomicilio.value    = auth.domicilioId;
                    selectDomicilio.disabled = true;
                    await cargarPropietarios(auth.domicilioId, auth.propietarioId);
                    selectPropietario.disabled = true;

                    // Ocultar selector de autorizaciones si estaba visible
                    document.getElementById('seccionSelectorAutorizacion').classList.add('d-none');

                    mensajeBusqueda.innerHTML =
                        '<span class="text-success fw-semibold">✓ Visitante autorizado — podés confirmar el ingreso directamente</span>';

                } else {
                    // Múltiples autorizaciones — mostrar selector
                    const seccionSelector = document.getElementById('seccionSelectorAutorizacion');
                    const selectAuth      = document.getElementById('selectAutorizacion');

                    selectAuth.innerHTML = '<option value="">-- Seleccioná el domicilio que viene a visitar --</option>';

                    data.autorizaciones.forEach((auth, index) => {
                        const opt       = document.createElement('option');
                        opt.value       = index;
                        opt.textContent = `${auth.domicilio} — ${auth.propietario} (${auth.tipo})`;
                        opt.dataset.domicilioId   = auth.domicilioId;
                        opt.dataset.propietarioId = auth.propietarioId;
                        opt.dataset.domicilio     = auth.domicilio;
                        opt.dataset.propietario   = auth.propietario;
                        opt.dataset.tipo          = auth.tipo;
                        selectAuth.appendChild(opt);
                    });

                    seccionSelector.classList.remove('d-none');

                    // Deshabilitar selects hasta que elija
                    selectDomicilio.disabled    = true;
                    selectPropietario.disabled  = true;

                    mensajeBusqueda.innerHTML =
                        '<span class="text-warning fw-semibold">⚠ El visitante tiene múltiples autorizaciones — seleccioná el domicilio que viene a visitar</span>';
                }
            } else {
                mensajeBusqueda.innerHTML =
                    '<span class="text-success">Visitante encontrado</span>';
            }

                seccionEncontrado.classList.remove('d-none');
                formRegistrar.classList.remove('d-none');
                seccionVisita.classList.remove('d-none');
                seccionBotones.classList.remove('d-none');

            } catch (e) {
                console.error(e);
                mensajeBusqueda.innerHTML =
                    '<span class="text-danger">Error al buscar. Intentá de nuevo.</span>';
            } finally {
                btnBuscar.disabled    = false;
                btnBuscar.textContent = 'Buscar';
            }
        }

        async function cargarPropietarios(domicilioId, preseleccionarId = null) {
            selectPropietario.innerHTML = '<option value="">-- Cargando... --</option>';
            selectPropietario.disabled  = true;

            try {
                const response     = await fetch(`/Visita/PropietariosPorDomicilio?domicilioId=${domicilioId}`);
                const propietarios = await response.json();

                selectPropietario.innerHTML =
                    '<option value="">-- Seleccionar propietario --</option>';

                propietarios.forEach(p => {
                    const opt       = document.createElement('option');
                    opt.value       = p.value;
                    opt.textContent = p.text;
                    selectPropietario.appendChild(opt);
                });

                if (preseleccionarId) {
                    selectPropietario.value = preseleccionarId;
                }

                selectPropietario.disabled = false;

            } catch {
                selectPropietario.innerHTML =
                    '<option value="">-- Error al cargar --</option>';
            }
        }

        selectDomicilio.addEventListener('change', async function () {
            if (this.disabled) return;
            document.getElementById('hiddenDomicilioId').value = this.value; // ✅
            if (!this.value) {
                selectPropietario.innerHTML =
                    '<option value="">-- Primero seleccioná un domicilio --</option>';
                selectPropietario.disabled = true;
                return;
            }
            await cargarPropietarios(this.value);
            selectPropietario.disabled = false;
        });

                selectPropietario.addEventListener('change', function () {
            document.getElementById('hiddenPropietarioId').value = this.value; // ✅
        });

            document.getElementById('selectAutorizacion')
        .addEventListener('change', async function () {
            const opt = this.options[this.selectedIndex];
            if (!opt.value) return;

            const domicilioId   = opt.dataset.domicilioId;
            const propietarioId = opt.dataset.propietarioId;

            document.getElementById('textoAutorizacionDomicilio').textContent  = opt.dataset.domicilio;
            document.getElementById('textoAutorizacionPropietario').textContent = opt.dataset.propietario;
            document.getElementById('textoAutorizacionTipo').textContent       = opt.dataset.tipo;

            document.getElementById('hiddenDomicilioId').value  = domicilioId;
            document.getElementById('hiddenPropietarioId').value = propietarioId;

            selectDomicilio.value    = domicilioId;
            selectDomicilio.disabled = true;
            await cargarPropietarios(domicilioId, propietarioId);
            selectPropietario.disabled = true;
        });

        btnBuscar.addEventListener('click', buscarVisitante);

        inputDni.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                buscarVisitante();
            }
        });

        inputDni.addEventListener('input', function () {
            if (!this.value.trim()) {
                resetFormulario();
                mensajeBusqueda.innerHTML = '';
            }
        });

                function resetFormulario() {
            formRegistrar.classList.add('d-none');
            seccionEncontrado.classList.add('d-none');
            seccionNuevo.classList.add('d-none');
            seccionVisita.classList.add('d-none');
            seccionBotones.classList.add('d-none');
            hiddenVisitanteId.value     = '';
            hiddenDni.value             = '';
            selectDomicilio.value       = '';
            selectDomicilio.disabled    = false;
            selectPropietario.innerHTML =
                '<option value="">-- Primero seleccioná un domicilio --</option>';
            selectPropietario.disabled  = true;
            document.getElementById('badgeAutorizacion').classList.add('d-none');
            document.getElementById('badgeAutorizacionTipo').classList.add('d-none'); // ✅ agregado
                document.getElementById('hiddenDomicilioId').value  = '';  // ✅
        document.getElementById('hiddenPropietarioId').value = ''; // ✅
            document.getElementById('seccionSelectorAutorizacion').classList.add('d-none');
        document.getElementById('selectAutorizacion').innerHTML =
            '<option value="">-- Seleccioná el domicilio que viene a visitar --</option>';
        }
    </script>
}